# Qwen Cloud (DashScope OpenAI-compatible mode)
DASHSCOPE_API_KEY=your_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Local dev defaults to SQLite; point this at Alibaba Cloud RDS/PolarDB in production.
# Note the driver prefix: use "postgresql+psycopg://" (not bare "postgresql://") since
# psycopg3 is what's pinned in requirements.txt, not psycopg2.
DATABASE_URL=sqlite:///./nexuschain_autopilot.db

# Optional: Slack Incoming Webhook URL for disruption-approval HITL messages.
# Leave blank to fall back to a local dev stub that just logs the message.
SLACK_WEBHOOK_URL=

# Estimated cost delta (USD) above which a disruption reroute always requires human
# approval, regardless of what the Qwen classifier decides.
DISRUPTION_COST_APPROVAL_THRESHOLD=200

# Alibaba Cloud OSS — archives raw request payloads for audit. Leave blank to fall back
# to writing under ./local_oss_store/ instead of calling the real API.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET_NAME=
